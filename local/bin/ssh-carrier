#!/usr/bin/env bash
# Open a long-lived SSH connection with agent forwarding to HOST and keep it
# alive.
#
# Assumes Tailscale SSH is enabled on the remote (`tailscale set --ssh` on the
# host). With that, tailscaled handles the SSH server side and accepts `none`
# auth based on WireGuard-verified tailnet identity — so no SSH key is sent,
# no 1Password Touch ID prompt fires on (re)connect.
#
# The forwarded $SSH_AUTH_SOCK still points at the laptop's 1Password agent,
# so remote operations that actually use keys (git push, ssh-add -l, etc.)
# prompt Touch ID at the right time.
#
# On the remote, ~/.ssh/agent_sock is repointed at the live forwarded socket
# so mosh shells and detached tmux panes can find an agent.
#
# Designed to be supervised by launchd (macOS). When this process exits
# (network drop, server reboot, sleep/wake) the supervisor respawns it.
#
# Usage: ssh-carrier HOST

set -euo pipefail

host=${1:?usage: ssh-carrier HOST}

exec ssh \
  -T -A \
  -o ServerAliveInterval=30 \
  -o ServerAliveCountMax=2 \
  -o ExitOnForwardFailure=yes \
  -o ConnectTimeout=10 \
  -o TCPKeepAlive=yes \
  -o BatchMode=yes \
  "$host" \
  'mkdir -p ~/.ssh && ln -sfn "$SSH_AUTH_SOCK" ~/.ssh/agent_sock && exec sleep 2147483647'
