#!/usr/bin/env bash
# Open a long-lived SSH connection with agent forwarding to HOST and keep it
# alive. On the remote, point ~/.ssh/agent_sock at the live forwarded socket
# so mosh shells and detached tmux panes can find an agent.
#
# Designed to be supervised by launchd (macOS) or systemd — when this process
# exits (network drop, server reboot, etc.) the supervisor respawns it, which
# re-points the remote symlink at the new forwarded socket.
#
# Usage: ssh-carrier HOST

set -euo pipefail

host=${1:?usage: ssh-carrier HOST}

exec ssh \
  -T -A \
  -o ServerAliveInterval=30 \
  -o ServerAliveCountMax=2 \
  -o ExitOnForwardFailure=yes \
  -o ConnectTimeout=10 \
  -o TCPKeepAlive=yes \
  -o BatchMode=yes \
  "$host" \
  'mkdir -p ~/.ssh && ln -sfn "$SSH_AUTH_SOCK" ~/.ssh/agent_sock && exec sleep 2147483647'
